<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#0F172A"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Expense"
            android:textColor="@android:color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />

        <TextView
            android:text="Record a new expense entry"
            android:textColor="@android:color/white"
            android:layout_marginBottom="16dp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            tools:ignore="HardcodedText" />


        <com.google.android.material.card.MaterialCardView
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#334155"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="2dp"
            app:strokeColor="#3B82F6">


        <LinearLayout
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/etCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select a category"
                    android:importantForAutofill="no"
                    android:minHeight="48dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#D1D5DB"
                    tools:ignore="HardcodedText,TextFields,VisualLintTextFieldSize" />

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Description"
                    android:importantForAutofill="no"
                    android:minHeight="48dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#D1D5DB"
                    tools:ignore="HardcodedText,TextFields,VisualLintTextFieldSize" />

                <EditText
                    android:id="@+id/etAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="0.00"
                    android:importantForAutofill="no"
                    android:inputType="numberDecimal"
                    android:minHeight="48dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#D1D5DB"
                    tools:ignore="HardcodedText,VisualLintTextFieldSize" />

                <EditText
                    android:id="@+id/etDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="YYYY-MM-DD"
                    android:importantForAutofill="no"
                    android:minHeight="48dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#D1D5DB"
                    tools:ignore="HardcodedText,TextFields,VisualLintTextFieldSize" />

                <!-- IMAGE PREVIEW -->
                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="12dp"
                    android:importantForAccessibility="no"
                    android:scaleType="centerCrop"
                    android:background="#334155" />

                <!-- SELECT IMAGE BUTTON -->
                <Button
                    android:id="@+id/btnSelectImage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select Image"
                    android:layout_marginTop="8dp"
                    tools:ignore="HardcodedText,VisualLintButtonSize" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ADD EXPENSE BUTTON (TOP) -->
            <Button
                android:id="@+id/btnAdd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add Expense"
                android:backgroundTint="#22C55E"
                android:textColor="@android:color/white"
                tools:ignore="HardcodedText,VisualLintButtonSize" />

            <!-- SPACE -->
            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"/>

            <!-- CANCEL BUTTON (BOTTOM, DARKER) -->
            <Button
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:backgroundTint="#334155"
                android:textColor="@android:color/white"
                tools:ignore="ButtonStyle,HardcodedText,VisualLintButtonSize" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>