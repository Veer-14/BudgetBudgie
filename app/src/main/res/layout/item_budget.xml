<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#0F172A"
    android:padding="12dp"
    android:layout_marginBottom="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- BUDGET NAME ROW -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="👤"
            android:textSize="16sp"
            android:layout_marginEnd="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvBudgetName"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- SUBTITLE -->
    <TextView
        android:id="@+id/tvBudgetAmount"
        android:textColor="#9CA3AF"
        android:textSize="13sp"
        android:layout_marginTop="2dp"
        android:layout_marginStart="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- SPENT / REMAINING ROW -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginStart="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content">

            <TextView
                android:text="Spent"
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvSpent"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content">

            <TextView
                android:text="Remaining"
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvRemaining"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </LinearLayout>

    <!-- PROGRESS BAR -->
    <ProgressBar
        android:id="@+id/progressBudget"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="24dp"
        android:progressTint="#6366F1"
        android:progressBackgroundTint="#334155"
        android:max="100"
        android:progress="0"/>

    <!-- MEMBER COUNT -->
    <TextView
        android:id="@+id/tvMemberCount"
        android:text="1 member"
        android:textColor="#9CA3AF"
        android:textSize="12sp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#334155"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"/>

    <!-- DETAILS HEADER -->
    <TextView
        android:id="@+id/tvDetailsHeader"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- TOTAL BUDGET BOX -->
    <LinearLayout
        android:orientation="vertical"
        android:background="#1E293B"
        android:padding="12dp"
        android:layout_marginBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Total Budget"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvTotalBudgetDetail"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- TOTAL SPENT BOX -->
    <LinearLayout
        android:orientation="vertical"
        android:background="#1E293B"
        android:padding="12dp"
        android:layout_marginBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Total Spent"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvTotalSpentDetail"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- REMAINING BOX -->
    <LinearLayout
        android:orientation="vertical"
        android:background="#1E293B"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Remaining"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvRemainingDetail"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#334155"
        android:layout_marginBottom="12dp"/>

    <!-- MEMBERS HEADER -->
    <TextView
        android:text="Members"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- MEMBERS LIST -->
    <LinearLayout
        android:id="@+id/membersContainer"
        android:orientation="vertical"
        android:background="#1E293B"
        android:padding="8dp"
        android:layout_marginBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- ADD MEMBER BUTTON -->
    <Button
        android:id="@+id/btnAddMember"
        android:text="👤 Add Member"
        android:background="#1E293B"
        android:textColor="#9CA3AF"
        android:layout_marginBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#334155"
        android:layout_marginBottom="12dp"/>

    <!-- ADD EXPENSE BUTTON -->
    <Button
        android:id="@+id/btnAddExpense"
        android:text="+ Add Expense"
        android:background="@drawable/bg_button"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#334155"
        android:layout_marginBottom="12dp"/>

    <!-- EXPENSES HEADER -->
    <TextView
        android:text="Expenses"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- EXPENSES LIST -->
    <LinearLayout
        android:id="@+id/expenseContainer"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>