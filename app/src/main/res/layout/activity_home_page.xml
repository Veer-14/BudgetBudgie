<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#0F172A"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Greeting -->
    <TextView
        android:id="@+id/txtGreeting"
        android:text="Hello, John Snow!"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_margin="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Here's your budget overview"
        android:textColor="#9CA3AF"
        android:layout_below="@id/txtGreeting"
        android:layout_marginStart="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Budget Card -->

    <!-- Total Spent Card -->

    <LinearLayout
        android:id="@+id/cardBudget"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_below="@id/txtGreeting"
        android:layout_margin="25dp"
        android:layout_marginTop="43dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/card_bg"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monthly Budget Status"
            android:textColor="#9CA3AF"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="R1754.50"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remaining"
            android:textColor="#9CA3AF" />

        <!-- Progress Bar -->
        <ProgressBar
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="20dp"
            android:max="100"
            android:progress="12"
            android:progressTint="#22C55E" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="R500 min"
                android:textColor="#9CA3AF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="12% used"
                android:textColor="#9CA3AF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="R2000 max"
                android:textColor="#9CA3AF" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/cardSpent"
        android:orientation="vertical"
        android:background="@drawable/card_dark"
        android:layout_below="@id/cardBudget"
        android:layout_margin="16dp"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="120dp">

        <TextView
            android:text="Total Spent This Month"
            android:textColor="#9CA3AF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="R245.50"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Total Expenses Card -->
    <LinearLayout
        android:id="@+id/cardExpenses"
        android:orientation="vertical"
        android:background="@drawable/card_dark"
        android:layout_below="@id/cardSpent"
        android:layout_margin="16dp"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="120dp">

        <TextView
            android:text="Total Expenses"
            android:textColor="#9CA3AF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="7"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Floating Add Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_above="@id/bottomNav"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#1E293B"
        android:src="@android:drawable/ic_input_add"
        tools:ignore="SpeakableTextPresentCheck" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_alignParentBottom="true"
        android:background="#1E293B"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:menu="@menu/bottom_menu"/>

</RelativeLayout>